&lt;a name="rest_code_02a0523dad0b4640a46e2f98619df3c9-34"&gt;&lt;/a&gt;        &lt;span class="k"&gt;yield&lt;/span&gt; &lt;span class="n"&gt;valuestr&lt;/span&gt;
