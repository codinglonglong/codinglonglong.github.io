&lt;pre class="code bash"&gt;&lt;a name="rest_code_04b575bafe1544668f65f222d0e5dce2-1"&gt;&lt;/a&gt;sudo service mysql stop
&lt;a name="rest_code_04b575bafe1544668f65f222d0e5dce2-2"&gt;&lt;/a&gt;mysqld
