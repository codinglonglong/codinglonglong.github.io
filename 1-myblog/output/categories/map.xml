&lt;a name="rest_code_2ff75d91fd5847e4aec7ba544d811689-5"&gt;&lt;/a&gt;
&lt;a name="rest_code_2ff75d91fd5847e4aec7ba544d811689-6"&gt;&lt;/a&gt;&lt;span class="kn"&gt;from&lt;/span&gt; &lt;span class="nn"&gt;multiprocessing&lt;/span&gt; &lt;span class="kn"&gt;import&lt;/span&gt; &lt;span class="n"&gt;Pool&lt;/span&gt;
&lt;a name="rest_code_2ff75d91fd5847e4aec7ba544d811689-7"&gt;&lt;/a&gt;&lt;span class="kn"&gt;from&lt;/span&gt; &lt;span class="nn"&gt;functools&lt;/span&gt; &lt;span class="kn"&gt;import&lt;/span&gt; &lt;span class="nb"&gt;reduce&lt;/span&gt;
