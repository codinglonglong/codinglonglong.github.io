&lt;a name="rest_code_02a0523dad0b4640a46e2f98619df3c9-7"&gt;&lt;/a&gt;    &lt;span class="n"&gt;thesum&lt;/span&gt; &lt;span class="o"&gt;=&lt;/span&gt; &lt;span class="mi"&gt;0&lt;/span&gt;
