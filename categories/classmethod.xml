&lt;a href="https://codinglonglong.github.io/posts/pythongou-zao-dui-xiang-bian-hao-zi-dong-jia-yi/#rest_code_dbe9bf490a564306b393c61df9b26068-4"&gt; 4&lt;/a&gt;
&lt;a href="https://codinglonglong.github.io/posts/pythongou-zao-dui-xiang-bian-hao-zi-dong-jia-yi/#rest_code_dbe9bf490a564306b393c61df9b26068-5"&gt; 5&lt;/a&gt;
&lt;a href="https://codinglonglong.github.io/posts/pythongou-zao-dui-xiang-bian-hao-zi-dong-jia-yi/#rest_code_dbe9bf490a564306b393c61df9b26068-6"&gt; 6&lt;/a&gt;
&lt;a href="https://codinglonglong.github.io/posts/pythongou-zao-dui-xiang-bian-hao-zi-dong-jia-yi/#rest_code_dbe9bf490a564306b393c61df9b26068-7"&gt; 7&lt;/a&gt;
&lt;a href="https://codinglonglong.github.io/posts/pythongou-zao-dui-xiang-bian-hao-zi-dong-jia-yi/#rest_code_dbe9bf490a564306b393c61df9b26068-8"&gt; 8&lt;/a&gt;
&lt;a href="https://codinglonglong.github.io/posts/pythongou-zao-dui-xiang-bian-hao-zi-dong-jia-yi/#rest_code_dbe9bf490a564306b393c61df9b26068-9"&gt; 9&lt;/a&gt;
&lt;a href="https://codinglonglong.github.io/posts/pythongou-zao-dui-xiang-bian-hao-zi-dong-jia-yi/#rest_code_dbe9bf490a564306b393c61df9b26068-10"&gt;10&lt;/a&gt;
&lt;a href="https://codinglonglong.github.io/posts/pythongou-zao-dui-xiang-bian-hao-zi-dong-jia-yi/#rest_code_dbe9bf490a564306b393c61df9b26068-11"&gt;11&lt;/a&gt;
&lt;a href="https://codinglonglong.github.io/posts/pythongou-zao-dui-xiang-bian-hao-zi-dong-jia-yi/#rest_code_dbe9bf490a564306b393c61df9b26068-12"&gt;12&lt;/a&gt;
&lt;a href="https://codinglonglong.github.io/posts/pythongou-zao-dui-xiang-bian-hao-zi-dong-jia-yi/#rest_code_dbe9bf490a564306b393c61df9b26068-13"&gt;13&lt;/a&gt;
&lt;a href="https://codinglonglong.github.io/posts/pythongou-zao-dui-xiang-bian-hao-zi-dong-jia-yi/#rest_code_dbe9bf490a564306b393c61df9b26068-14"&gt;14&lt;/a&gt;
&lt;a href="https://codinglonglong.github.io/posts/pythongou-zao-dui-xiang-bian-hao-zi-dong-jia-yi/#rest_code_dbe9bf490a564306b393c61df9b26068-15"&gt;15&lt;/a&gt;
&lt;a href="https://codinglonglong.github.io/posts/pythongou-zao-dui-xiang-bian-hao-zi-dong-jia-yi/#rest_code_dbe9bf490a564306b393c61df9b26068-16"&gt;16&lt;/a&gt;
&lt;a href="https://codinglonglong.github.io/posts/pythongou-zao-dui-xiang-bian-hao-zi-dong-jia-yi/#rest_code_dbe9bf490a564306b393c61df9b26068-17"&gt;17&lt;/a&gt;
&lt;a href="https://codinglonglong.github.io/posts/pythongou-zao-dui-xiang-bian-hao-zi-dong-jia-yi/#rest_code_dbe9bf490a564306b393c61df9b26068-18"&gt;18&lt;/a&gt;
&lt;a href="https://codinglonglong.github.io/posts/pythongou-zao-dui-xiang-bian-hao-zi-dong-jia-yi/#rest_code_dbe9bf490a564306b393c61df9b26068-19"&gt;19&lt;/a&gt;
&lt;a href="https://codinglonglong.github.io/posts/pythongou-zao-dui-xiang-bian-hao-zi-dong-jia-yi/#rest_code_dbe9bf490a564306b393c61df9b26068-20"&gt;20&lt;/a&gt;
&lt;a href="https://codinglonglong.github.io/posts/pythongou-zao-dui-xiang-bian-hao-zi-dong-jia-yi/#rest_code_dbe9bf490a564306b393c61df9b26068-21"&gt;21&lt;/a&gt;
&lt;a href="https://codinglonglong.github.io/posts/pythongou-zao-dui-xiang-bian-hao-zi-dong-jia-yi/#rest_code_dbe9bf490a564306b393c61df9b26068-22"&gt;22&lt;/a&gt;
&lt;a href="https://codinglonglong.github.io/posts/pythongou-zao-dui-xiang-bian-hao-zi-dong-jia-yi/#rest_code_dbe9bf490a564306b393c61df9b26068-23"&gt;23&lt;/a&gt;
&lt;a href="https://codinglonglong.github.io/posts/pythongou-zao-dui-xiang-bian-hao-zi-dong-jia-yi/#rest_code_dbe9bf490a564306b393c61df9b26068-24"&gt;24&lt;/a&gt;
&lt;a href="https://codinglonglong.github.io/posts/pythongou-zao-dui-xiang-bian-hao-zi-dong-jia-yi/#rest_code_dbe9bf490a564306b393c61df9b26068-25"&gt;25&lt;/a&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/td&gt;&lt;td class="code"&gt;&lt;pre class="code python"&gt;&lt;a name="rest_code_dbe9bf490a564306b393c61df9b26068-1"&gt;&lt;/a&gt;&lt;span class="k"&gt;class&lt;/span&gt; &lt;span class="nc"&gt;Stu&lt;/span&gt;&lt;span class="p"&gt;:&lt;/span&gt;
&lt;a name="rest_code_dbe9bf490a564306b393c61df9b26068-2"&gt;&lt;/a&gt;
&lt;a name="rest_code_dbe9bf490a564306b393c61df9b26068-3"&gt;&lt;/a&gt;    &lt;span class="k"&gt;def&lt;/span&gt; &lt;span class="nf"&gt;__init__&lt;/span&gt;&lt;span class="p"&gt;(&lt;/span&gt;&lt;span class="bp"&gt;self&lt;/span&gt;&lt;span class="p"&gt;):&lt;/span&gt;
&lt;a name="rest_code_dbe9bf490a564306b393c61df9b26068-4"&gt;&lt;/a&gt;        &lt;span class="bp"&gt;self&lt;/span&gt;&lt;span class="o"&gt;.&lt;/span&gt;&lt;span class="n"&gt;id&lt;/span&gt; &lt;span class="o"&gt;=&lt;/span&gt; &lt;span class="bp"&gt;self&lt;/span&gt;&lt;span class="o"&gt;.&lt;/span&gt;&lt;span class="n"&gt;getnewid&lt;/span&gt;&lt;span class="p"&gt;()&lt;/span&gt;
&lt;a name="rest_code_dbe9bf490a564306b393c61df9b26068-5"&gt;&lt;/a&gt;        &lt;span class="bp"&gt;self&lt;/span&gt;&lt;span class="o"&gt;.&lt;/span&gt;&lt;span class="n"&gt;name&lt;/span&gt; &lt;span class="o"&gt;=&lt;/span&gt; &lt;span class="s2"&gt;"写程序的龙龙"&lt;/span&gt;
&lt;a name="rest_code_dbe9bf490a564306b393c61df9b26068-6"&gt;&lt;/a&gt;        &lt;span class="bp"&gt;self&lt;/span&gt;&lt;span class="o"&gt;.&lt;/span&gt;&lt;span class="n"&gt;url&lt;/span&gt; &lt;span class="o"&gt;=&lt;/span&gt; &lt;span class="s2"&gt;"https://codinglonglong.github.io"&lt;/span&gt;
&lt;a name="rest_code_dbe9bf490a564306b393c61df9b26068-7"&gt;&lt;/a&gt;
&lt;a name="rest_code_dbe9bf490a564306b393c61df9b26068-8"&gt;&lt;/a&gt;    &lt;span class="k"&gt;def&lt;/span&gt; &lt;span class="nf"&gt;__str__&lt;/span&gt;&lt;span class="p"&gt;(&lt;/span&gt;&lt;span class="bp"&gt;self&lt;/span&gt;&lt;span class="p"&gt;):&lt;/span&gt;
&lt;a name="rest_code_dbe9bf490a564306b393c61df9b26068-9"&gt;&lt;/a&gt;        &lt;span class="k"&gt;return&lt;/span&gt; &lt;span class="s2"&gt;"id: "&lt;/span&gt; &lt;span class="o"&gt;+&lt;/span&gt; &lt;span class="nb"&gt;str&lt;/span&gt;&lt;span class="p"&gt;(&lt;/span&gt;&lt;span class="bp"&gt;self&lt;/span&gt;&lt;span class="o"&gt;.&lt;/span&gt;&lt;span class="n"&gt;newid&lt;/span&gt;&lt;span class="p"&gt;)&lt;/span&gt; &lt;span class="o"&gt;+&lt;/span&gt; &lt;span class="s2"&gt;"&lt;/span&gt;&lt;span class="se"&gt;\n&lt;/span&gt;&lt;span class="s2"&gt;"&lt;/span&gt; &lt;span class="o"&gt;+&lt;/span&gt; \
&lt;a name="rest_code_dbe9bf490a564306b393c61df9b26068-10"&gt;&lt;/a&gt;            &lt;span class="s2"&gt;"name: "&lt;/span&gt; &lt;span class="o"&gt;+&lt;/span&gt; &lt;span class="nb"&gt;str&lt;/span&gt;&lt;span class="p"&gt;(&lt;/span&gt;&lt;span class="bp"&gt;self&lt;/span&gt;&lt;span class="o"&gt;.&lt;/span&gt;&lt;span class="n"&gt;name&lt;/span&gt;&lt;span class="p"&gt;)&lt;/span&gt; &lt;span class="o"&gt;+&lt;/span&gt; &lt;span class="s2"&gt;"&lt;/span&gt;&lt;span class="se"&gt;\n&lt;/span&gt;&lt;span class="s2"&gt;"&lt;/span&gt; &lt;span class="o"&gt;+&lt;/span&gt; \
&lt;a name="rest_code_dbe9bf490a564306b393c61df9b26068-11"&gt;&lt;/a&gt;            &lt;span class="s2"&gt;"blog: "&lt;/span&gt; &lt;span class="o"&gt;+&lt;/span&gt; &lt;span class="nb"&gt;str&lt;/span&gt;&lt;span class="p"&gt;(&lt;/span&gt;&lt;span class="bp"&gt;self&lt;/span&gt;&lt;span class="o"&gt;.&lt;/span&gt;&lt;span class="n"&gt;url&lt;/span&gt;&lt;span class="p"&gt;)&lt;/span&gt;
&lt;a name="rest_code_dbe9bf490a564306b393c61df9b26068-12"&gt;&lt;/a&gt;
&lt;a name="rest_code_dbe9bf490a564306b393c61df9b26068-13"&gt;&lt;/a&gt;    &lt;span class="n"&gt;newid&lt;/span&gt; &lt;span class="o"&gt;=&lt;/span&gt; &lt;span class="mi"&gt;0&lt;/span&gt;
&lt;a name="rest_code_dbe9bf490a564306b393c61df9b26068-14"&gt;&lt;/a&gt;
&lt;a name="rest_code_dbe9bf490a564306b393c61df9b26068-15"&gt;&lt;/a&gt;    &lt;span class="nd"&gt;@classmethod&lt;/span&gt;
&lt;a name="rest_code_dbe9bf490a564306b393c61df9b26068-16"&gt;&lt;/a&gt;    &lt;span class="k"&gt;def&lt;/span&gt; &lt;span class="nf"&gt;getnewid&lt;/span&gt;&lt;span class="p"&gt;(&lt;/span&gt;&lt;span class="n"&gt;cls&lt;/span&gt;&lt;span class="p"&gt;):&lt;/span&gt;
&lt;a name="rest_code_dbe9bf490a564306b393c61df9b26068-17"&gt;&lt;/a&gt;        &lt;span class="n"&gt;cls&lt;/span&gt;&lt;span class="o"&gt;.&lt;/span&gt;&lt;span class="n"&gt;newid&lt;/span&gt; &lt;span class="o"&gt;=&lt;/span&gt; &lt;span class="n"&gt;cls&lt;/span&gt;&lt;span class="o"&gt;.&lt;/span&gt;&lt;span class="n"&gt;newid&lt;/span&gt; &lt;span class="o"&gt;+&lt;/span&gt; &lt;span class="mi"&gt;1&lt;/span&gt;
&lt;a name="rest_code_dbe9bf490a564306b393c61df9b26068-18"&gt;&lt;/a&gt;        &lt;span class="k"&gt;return&lt;/span&gt; &lt;span class="n"&gt;cls&lt;/span&gt;&lt;span class="o"&gt;.&lt;/span&gt;&lt;span class="n"&gt;newid&lt;/span&gt;
&lt;a name="rest_code_dbe9bf490a564306b393c61df9b26068-19"&gt;&lt;/a&gt;
&lt;a name="rest_code_dbe9bf490a564306b393c61df9b26068-20"&gt;&lt;/a&gt;
&lt;a name="rest_code_dbe9bf490a564306b393c61df9b26068-21"&gt;&lt;/a&gt;&lt;span class="n"&gt;stu1&lt;/span&gt; &lt;span class="o"&gt;=&lt;/span&gt; &lt;span class="n"&gt;Stu&lt;/span&gt;&lt;span class="p"&gt;()&lt;/span&gt;
&lt;a name="rest_code_dbe9bf490a564306b393c61df9b26068-22"&gt;&lt;/a&gt;&lt;span class="k"&gt;print&lt;/span&gt;&lt;span class="p"&gt;(&lt;/span&gt;&lt;span class="n"&gt;stu1&lt;/span&gt;&lt;span class="p"&gt;)&lt;/span&gt;
&lt;a name="rest_code_dbe9bf490a564306b393c61df9b26068-23"&gt;&lt;/a&gt;&lt;span class="k"&gt;print&lt;/span&gt;&lt;span class="p"&gt;(&lt;/span&gt;&lt;span class="s2"&gt;"*"&lt;/span&gt; &lt;span class="o"&gt;*&lt;/span&gt; &lt;span class="mi"&gt;50&lt;/span&gt;&lt;span class="p"&gt;)&lt;/span&gt;
&lt;a name="rest_code_dbe9bf490a564306b393c61df9b26068-24"&gt;&lt;/a&gt;&lt;span class="n"&gt;stu2&lt;/span&gt; &lt;span class="o"&gt;=&lt;/span&gt; &lt;span class="n"&gt;Stu&lt;/span&gt;&lt;span class="p"&gt;()&lt;/span&gt;
&lt;a name="rest_code_dbe9bf490a564306b393c61df9b26068-25"&gt;&lt;/a&gt;&lt;span class="k"&gt;print&lt;/span&gt;&lt;span class="p"&gt;(&lt;/span&gt;&lt;span class="n"&gt;stu2&lt;/span&gt;&lt;span class="p"&gt;)&lt;/span&gt;
&lt;/pre&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;p&gt;运行程序，得到如下结果：&lt;/p&gt;
&lt;pre class="literal-block"&gt;
&amp;gt;&amp;gt; long@mylife:~$ python3 test.py
&amp;gt;&amp;gt; id: 1
&amp;gt;&amp;gt; name: 写程序的龙龙
&amp;gt;&amp;gt; blog: https://codinglonglong.github.io
&amp;gt;&amp;gt; **************************************************
&amp;gt;&amp;gt; id: 2
&amp;gt;&amp;gt; name: 写程序的龙龙
&amp;gt;&amp;gt; blog: https://codinglonglong.github.io
&lt;/pre&gt;
&lt;p&gt;我们看到，每初始化一个对象，对象的id就增加了1。&lt;/p&gt;&lt;/div&gt;</description><category>classmethod</category><category>Python</category><guid>https://codinglonglong.github.io/posts/pythongou-zao-dui-xiang-bian-hao-zi-dong-jia-yi/</guid><pubDate>Tue, 08 Sep 2015 02:46:21 GMT</pubDate></item></channel></rss>