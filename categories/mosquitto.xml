&lt;p&gt;1、安装mosquitto服务器。&lt;/p&gt;
&lt;blockquote&gt;
&lt;pre class="code bash"&gt;&lt;a name="rest_code_ec3f709146a34f9ca3741d39eff702e6-1"&gt;&lt;/a&gt;&amp;gt;&amp;gt; apt install wget
&lt;a name="rest_code_ec3f709146a34f9ca3741d39eff702e6-2"&gt;&lt;/a&gt;&amp;gt;&amp;gt; wget http://mosquitto.org/files/source/mosquitto-1.4.11.tar.gz
&lt;a name="rest_code_ec3f709146a34f9ca3741d39eff702e6-3"&gt;&lt;/a&gt;&amp;gt;&amp;gt; tar zxvf mosquitto-1.4.11.tar.gz
&lt;a name="rest_code_ec3f709146a34f9ca3741d39eff702e6-4"&gt;&lt;/a&gt;&amp;gt;&amp;gt; &lt;span class="nb"&gt;cd&lt;/span&gt; mosquitto-1.4.11
&lt;a name="rest_code_ec3f709146a34f9ca3741d39eff702e6-5"&gt;&lt;/a&gt;&amp;gt;&amp;gt; apt install libc-ares-dev uuid-dev libwebsockets-dev libssl-dev
